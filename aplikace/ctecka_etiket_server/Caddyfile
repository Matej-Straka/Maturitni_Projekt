# Caddyfile pro ctecka_etiket projekt
# Nahraď "moje-app.duckdns.org" svojí doménou z DuckDNS.

moje-app.duckdns.org {
    # Preflight requests for browser CORS on static content/upload routes.
    @uploadsPreflight {
        method OPTIONS
        path /uploads/* /upload
    }
    handle @uploadsPreflight {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, x-upload-token"
        header Access-Control-Max-Age "86400"
        respond "" 204
    }

    # Statické soubory (obrázky, videa) + CORS hlavičky pro web klienty.
    handle /upload {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, x-upload-token"
        reverse_proxy localhost:8090
    }

    handle_path /uploads/* {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, x-upload-token"
        reverse_proxy localhost:8090
    }

    # API endpointy
    handle {
        reverse_proxy localhost:8080
    }
}

# Nebo pokud chceš oddělené subdomény:
# 
# api.moje-app.duckdns.org {
#     reverse_proxy localhost:8080
# }
#
# static.moje-app.duckdns.org {
#     reverse_proxy localhost:8090
# }
